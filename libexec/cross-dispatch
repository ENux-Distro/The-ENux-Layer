#!/bin/sh
# cross-dispatch - run a command inside whichever layer provides it.
#
# The non-FUSE equivalent of Bedrock's crossfs. /enux/cross/bin/<cmd> is a
# symlink to this script; it looks <cmd> up in the cross index and re-execs
# it inside the owning layer (via `layer enter`, so the command runs with
# its own layer's libc and libraries - that is why a foreign binary like
# Alpine's musl-linked apk works from a glibc base).
#
# The index is built by `enux cross`.

set -eu

CROSS_DIR="${CROSS_DIR:-/enux/cross}"
CROSS_INDEX="${CROSS_INDEX:-$CROSS_DIR/index}"
BIN_DIR="${BIN_DIR:-/enux/bin}"
LAYER_DIR="${LAYER_DIR:-/enux/layer}"
LIBEXEC_DIR="${LIBEXEC_DIR:-/enux/libexec}"

# Remove the cross dir from PATH first, so this script's own helpers
# (basename, awk) and the `layer` it execs resolve to base binaries and
# never loop back into a cross wrapper (which would recurse forever).
case ":$PATH:" in
*":$CROSS_DIR/bin:"*)
    _np=""; _oifs=$IFS; IFS=:
    for _p in $PATH; do
        [ "$_p" = "$CROSS_DIR/bin" ] && continue
        _np="${_np:+$_np:}$_p"
    done
    IFS=$_oifs
    PATH=$_np; export PATH
    ;;
esac

cmd=$(basename "$0")

# Index line: "<cmd> <layer> <absolute-path-inside-layer>"
entry=$(awk -v c="$cmd" '$1 == c { print $2, $3; exit }' "$CROSS_INDEX" 2>/dev/null || true)
if [ -z "$entry" ]; then
    echo "cross: no layer provides '$cmd' (run 'enux cross' to refresh)" >&2
    exit 127
fi
layer=${entry%% *}
inpath=${entry#* }

# Package managers: when already root, run via a privileged chroot into the
# owning layer (same path pmm uses) and refresh the cross index after so
# newly installed commands are typeable immediately. When NOT root, fall
# through to layer-chroot below - read ops (search/show/list) work fine as
# the user; write ops (install/remove) will fail with "permission denied" so
# the user knows to prefix with sudo, exactly like on any normal system.
# No auto-sudo: the user decides when to escalate.
case "$cmd" in
apt|apt-get|aptitude|dpkg|dnf|dnf5|yum|microdnf|rpm|pacman|apk|\
xbps-install|xbps-remove|xbps-query|zypper|emerge)
    if [ "$(id -u)" = 0 ]; then
        "$BIN_DIR/layer" enter "$layer" "$inpath" "$@"
        rc=$?
        # Rebuild cross index synchronously so new commands exist before the
        # prompt returns. Synchronous is required: a background rebuild leaves
        # a window where the symlink does not exist yet, and bash's hash table
        # caches the "not found" result for the life of the shell.
        printf '[enux] cross is rebuilding...\n' >&2
        "$BIN_DIR/enux" cross >/dev/null 2>&1 || true
        exit "$rc"
    fi
    ;;
esac

# The enux layer is the ENux base itself - its commands need no separate
# filesystem view, so run them via the base's own dynamic loader: a single
# exec, no namespace setup, no root. (The caller's uid, cwd and /home are
# preserved since it runs in the current namespace.)
if [ "$layer" = enux ]; then
    el="$LAYER_DIR/enux"
    ld=""
    for c in "$el"/lib64/ld-linux-*.so.*; do
        [ -e "$c" ] && { ld="$c"; break; }
    done
    if [ -n "$ld" ] && [ -x "$el$inpath" ]; then
        exec "$ld" --library-path "$el/usr/lib:$el/usr/lib64:$el/lib64:$el/lib" \
            "$el$inpath" "$@"
    fi
fi

# Every other layer: run the command in its layer's FULL view, as the calling
# user, via layer-chroot - a cap_sys_chroot helper inspired by Bedrock Linux
# 1.0beta1. Plain chroot (no user namespace) works on the base AND nested
# inside a --gui desktop chroot, needs no sudo, and gives the command its own
# /etc,/usr + interpreters (scripts, rpm's rpmrc, GUI apps all work with the
# user's own identity and X authority). Primary path; the layer must already be
# enabled (boot-time init.c does this for every layer).
if [ -x "$LIBEXEC_DIR/layer-chroot" ]; then
    exec "$LIBEXEC_DIR/layer-chroot" "$layer" "$inpath" "$@"
fi

# Fallback (no layer-chroot): layer-cross (bubblewrap) - own view as the caller,
# no root, but limited inside a chroot (no nested userns) and unable to run scripts.
if [ -x "$LIBEXEC_DIR/layer-cross" ]; then
    exec "$LIBEXEC_DIR/layer-cross" "$layer" "$inpath" "$@"
fi

# Last resort (no bwrap / no layer-cross): privileged chroot enter (needs root).
exec "$BIN_DIR/layer" enter "$layer" "$inpath" "$@"
