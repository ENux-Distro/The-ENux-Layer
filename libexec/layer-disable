#!/bin/sh
# layer-disable - reverse of layer-enable
#
# Usage: layer-disable <name>
#
# Lazy-unmounts (-l) every mount at or under the layer root, deepest-first
# and repeatedly, until none remain. Draining in a loop matters because a
# layer can accumulate STACKED mounts (each enable adds binds; an
# interrupted run can leave several on the same path) - unmounting once
# would leave the rest behind and block an ISO build. Lazy unmount also
# means a lingering process with its cwd inside the layer doesn't block
# teardown: the mount detaches now, the fs frees when that process exits.

set -eu

LAYER_DIR="${LAYER_DIR:-/enux/layer}"

if [ "$#" -ne 1 ]; then
    echo "usage: layer-disable <name>" >&2
    exit 2
fi

name="$1"
root="$LAYER_DIR/$name"

# Every mountpoint at or under $root, deepest first (longest path first),
# so children unmount before parents.
mounts_under_root()
{
    awk -v r="$root" '$5 == r || index($5, r "/") == 1 { print $5 }' \
        /proc/self/mountinfo \
        | awk '{ print length, $0 }' | sort -rn | cut -d' ' -f2-
}

pass=0
while :; do
    mounts=$(mounts_under_root)
    [ -z "$mounts" ] && break
    printf '%s\n' "$mounts" | while IFS= read -r m; do
        [ -n "$m" ] && umount -l "$m" 2>/dev/null || true
    done
    pass=$((pass + 1))
    if [ "$pass" -ge 50 ]; then
        echo "layer-disable: '$name' still has mounts after 50 passes" >&2
        exit 1
    fi
done

