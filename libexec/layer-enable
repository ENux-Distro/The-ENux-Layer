#!/bin/sh
# layer-enable - make a layer's rootfs usable in a chroot/non-PID-1 environment
#
# Usage: layer-enable <name>
#
# Bind-mounts the layer onto itself so it gets its own /proc/self/mountinfo
# entry (without this, tools like pacman that walk mountinfo to find a
# path's mountpoint fail with bogus "no space" errors - see commit history
# for the reproduction), then brings in /proc, /sys, /dev, /dev/pts from
# the host and a copy of resolv.conf for DNS.
#
# Idempotent: running this twice on an already-enabled layer is a no-op.

set -eu

LAYER_DIR="${LAYER_DIR:-/enux/layer}"

if [ "$#" -ne 1 ]; then
    echo "usage: layer-enable <name>" >&2
    exit 2
fi

name="$1"
root="$LAYER_DIR/$name"

if [ ! -d "$root" ]; then
    echo "layer-enable: '$name' is not installed at $root" >&2
    exit 1
fi

is_mounted()
{
    # Match "<mountpoint> " as a whole field in mountinfo, not a substring,
    # so /enux/layer/arch doesn't false-match /enux/layer/arch2.
    awk -v p="$1" '$5 == p { found=1 } END { exit !found }' /proc/self/mountinfo
}

bind_if_needed()
{
    src="$1"
    dst="$2"
    if is_mounted "$dst"; then
        return 0
    fi
    mount --bind "$src" "$dst"
}

# Self-bind first - everything else depends on $root having a mountinfo
# entry of its own. Without --make-private, the self-bind stays in the
# same propagation group as the underlying root mount, so every bind we
# do underneath it (proc, sys, dev...) gets propagated back through both
# paths to the same directory and shows up twice in mountinfo.
bind_if_needed "$root" "$root"
mount --make-private "$root"

mkdir -p "$root/proc" "$root/sys" "$root/dev" "$root/dev/pts"
bind_if_needed /proc "$root/proc"
bind_if_needed /sys "$root/sys"
bind_if_needed /dev "$root/dev"
bind_if_needed /dev/pts "$root/dev/pts"

# Share the host's X11 socket so GUI programs in the layer can reach a
# running display (cross-layer apps). Harmless when no X server is up.
# /dev/dri and /dev/input come in via the /dev bind above.
if [ -d /tmp/.X11-unix ]; then
    mkdir -p "$root/tmp/.X11-unix"
    bind_if_needed /tmp/.X11-unix "$root/tmp/.X11-unix"
fi

# Share udev's runtime database. X's libinput driver finds input devices
# and reads their ID_INPUT_* tags from /run/udev/data, not from /dev - so
# without this the mouse and keyboard are dead in a layer's X session even
# though /dev/input is present.
if [ -d /run/udev ]; then
    mkdir -p "$root/run/udev"
    bind_if_needed /run/udev "$root/run/udev"
fi

# Global view (ENUX_SHARE_GLOBAL=1): share the base system's user data and
# runtime into the layer so a desktop session run from the layer operates
# on the real ENux home, drives, processes, and system bus rather than the
# layer's isolated copies. The layer keeps its own OS dirs (/usr, /lib,
# /etc, /bin, /sbin, /var) - that is where its binaries, their loadable
# modules, and config live, so X stays Debian's while "/" is ENux's where
# it matters to the user. Each dir is shared only if it exists on the base.
# /root is deliberately NOT shared: a desktop started with `startx` reads
# its session config (~/.xinitrc) from the layer's /root, so replacing it
# with the base's would break session launch. User data lives in /home.
if [ "${ENUX_SHARE_GLOBAL:-0}" = 1 ]; then
    for gd in home mnt media opt srv run/dbus run/user; do
        [ -e "/$gd" ] || continue
        mkdir -p "$root/$gd"
        bind_if_needed "/$gd" "$root/$gd"
    done

    # Mirror the base /enux into the layer so a desktop session has live,
    # direct access to every stratum (/enux/layer/*) and the tooling, with
    # no duplication. NON-recursive (--bind via bind_if_needed) on purpose:
    # the strata's own /proc,/dev,self-bind submounts must NOT be pulled in,
    # or they tangle. This shadows the layer's own copied /enux/bin etc. with
    # the live base set. Note: /enux/layer/<this layer> then points back at
    # the layer's own root - harmless to read, but do not re-enable/enter
    # THIS layer from inside itself (that would recurse).
    if [ -d /enux ]; then
        mkdir -p "$root/enux"
        bind_if_needed /enux "$root/enux"
    fi
fi

# DNS: copy a real resolv.conf into the layer for the chroot session.
# Many distros ship /etc/resolv.conf as a symlink (Fedora -> /run/systemd/
# resolve/stub-resolv.conf). If we don't remove that first, cp follows the
# dangling symlink and writes through an absolute target resolved against
# the HOST root - the layer ends up with no working resolver, and we've
# scribbled on the host's /run. Replace it with a plain file instead.
if [ -e /etc/resolv.conf ] || [ -L /etc/resolv.conf ]; then
    rm -f "$root/etc/resolv.conf"
    cp -L /etc/resolv.conf "$root/etc/resolv.conf" 2>/dev/null || true
fi

echo "layer-enable: '$name' ready at $root"
