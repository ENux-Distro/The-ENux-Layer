#!/bin/sh
# layer - thin dispatcher over the libexec layer-* tools (the strat clone)
#
# Usage:
#   layer enable  <name>
#   layer disable <name>
#   layer enter   <name> [command [args...]]
#   layer list

set -eu

LIBEXEC_DIR="${LIBEXEC_DIR:-/enux/libexec}"
LAYER_DIR="${LAYER_DIR:-/enux/layer}"
CROSS_DIR="${CROSS_DIR:-/enux/cross}"

# Strip the cross dir from PATH: the mount/chroot machinery must use the
# base system's own mount/awk/cp, never a layer's cross-dispatched ones.
case ":$PATH:" in
*":$CROSS_DIR/bin:"*)
    _np=""; _oifs=$IFS; IFS=:
    for _p in $PATH; do
        [ "$_p" = "$CROSS_DIR/bin" ] && continue
        _np="${_np:+$_np:}$_p"
    done
    IFS=$_oifs
    PATH=$_np; export PATH
    ;;
esac

usage()
{
    echo "usage: layer enable <name>" >&2
    echo "       layer disable <name>" >&2
    echo "       layer enter [--global] [--user|--gui] <name> [command [args...]]" >&2
    echo "       layer list" >&2
    exit 2
}

is_mounted_layer()
{
    awk -v p="$LAYER_DIR/$1" '$5 == p { found=1 } END { exit !found }' \
        /proc/self/mountinfo
}

# Operations that bind-mount and chroot need root; bail early with a clear
# message instead of letting mount/chroot spew permission errors.
need_root()
{
    [ "$(id -u)" -eq 0 ] && return 0
    echo "layer: '$1' needs root privileges. Re-run with: sudo layer $1 ..." >&2
    exit 1
}

[ "$#" -ge 1 ] || usage
cmd="$1"
shift

case "$cmd" in
enable)
    [ "$#" -eq 1 ] || usage
    need_root enable
    exec "$LIBEXEC_DIR/layer-enable" "$1"
    ;;
disable)
    [ "$#" -eq 1 ] || usage
    need_root disable
    exec "$LIBEXEC_DIR/layer-disable" "$1"
    ;;
enter)
    [ "$#" -ge 1 ] || usage
    need_root enter
    exec "$LIBEXEC_DIR/layer-enter" "$@"
    ;;
list)
    [ -d "$LAYER_DIR" ] || { echo "no layers installed"; exit 0; }
    for d in "$LAYER_DIR"/*/; do
        [ -d "$d" ] || continue
        name=$(basename "$d")
        if is_mounted_layer "$name"; then
            state="enabled"
        else
            state="disabled"
        fi
        printf '%-20s %s\n' "$name" "$state"
    done
    ;;
*)
    usage
    ;;
esac
