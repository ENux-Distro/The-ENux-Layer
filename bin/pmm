#!/bin/sh
# pmm - package manager manager: one front-end over each layer's native
#       package manager (the Bedrock pmm clone).
#
# Usage:
#   pmm <operation> [layer:<name>] [packages...]
#
# Operations:
#   install   install packages
#   remove    remove packages
#   update    refresh the package database / metadata
#   upgrade   upgrade all installed packages
#   search    search for a package
#   list      list installed packages
#   clean     clear the downloaded-package cache
#
# Target layer: an explicit `layer:<name>` argument always wins. Otherwise
# the target depends on the operation (mirrors Bedrock pmm):
#   install            first layer (exec_order priority) that HAS the package
#   remove             every layer that has the command installed
#   update/upgrade     every installed layer
#   search/list        every installed layer
# The native package manager is detected from the layer's rootfs, so
# `pmm install neofetch` does the right thing whether the chosen layer is
# Arch (pacman), Fedora (dnf), Alpine (apk)...

set -eu

BIN_DIR="${BIN_DIR:-/enux/bin}"
LAYER_DIR="${LAYER_DIR:-/enux/layer}"

usage()
{
    cat >&2 <<'EOF'
usage: pmm <operation> [layer:<name>] [packages...]

operations: install remove update upgrade search list clean
EOF
    exit 2
}

# Detect the native package manager by looking for its binary in the
# layer's rootfs. No chroot needed - we only stat files.
detect_pm()
{
    root="$1"
    for pm in pacman apt-get dnf apk xbps-install zypper emerge; do
        for d in usr/bin bin usr/sbin sbin; do
            if [ -x "$root/$d/$pm" ]; then
                echo "$pm"
                return 0
            fi
        done
    done
    return 1
}

# Echo the native command for (pm, operation). Packages are appended by
# the caller. Operations with no sensible mapping echo nothing -> error.
pm_command()
{
    pm="$1"
    op="$2"
    case "$pm:$op" in
    pacman:install)   echo "pacman -S --noconfirm" ;;
    pacman:remove)    echo "pacman -R --noconfirm" ;;
    pacman:update)    echo "pacman -Sy" ;;
    pacman:upgrade)   echo "pacman -Syu --noconfirm" ;;
    pacman:search)    echo "pacman -Ss" ;;
    pacman:list)      echo "pacman -Q" ;;

    apt-get:install)  echo "apt-get install -y" ;;
    apt-get:remove)   echo "apt-get remove -y" ;;
    apt-get:update)   echo "apt-get update" ;;
    apt-get:upgrade)  echo "apt-get upgrade -y" ;;
    apt-get:search)   echo "apt-cache search" ;;
    apt-get:list)     echo "dpkg -l" ;;

    # dnf update uses makecache, not check-update: check-update exits 100
    # when updates exist, which would look like a failure under set -e.
    dnf:install)      echo "dnf install -y" ;;
    dnf:remove)       echo "dnf remove -y" ;;
    dnf:update)       echo "dnf makecache" ;;
    dnf:upgrade)      echo "dnf upgrade -y" ;;
    dnf:search)       echo "dnf search" ;;
    dnf:list)         echo "dnf list --installed" ;;

    apk:install)      echo "apk add -U" ;;  # -U: refresh index first (like pacman -Sy)
    apk:remove)       echo "apk del" ;;
    apk:update)       echo "apk update" ;;
    apk:upgrade)      echo "apk upgrade" ;;
    apk:search)       echo "apk search" ;;
    apk:list)         echo "apk info" ;;

    xbps-install:install)  echo "xbps-install -Sy" ;;  # -S syncs the repo index first
    xbps-install:remove)   echo "xbps-remove -y" ;;
    xbps-install:update)   echo "xbps-install -S" ;;
    xbps-install:upgrade)  echo "xbps-install -Su" ;;
    xbps-install:search)   echo "xbps-query -Rs" ;;
    xbps-install:list)     echo "xbps-query -l" ;;

    zypper:install)   echo "zypper install -y" ;;
    zypper:remove)    echo "zypper remove -y" ;;
    zypper:update)    echo "zypper refresh" ;;
    zypper:upgrade)   echo "zypper update -y" ;;
    zypper:search)    echo "zypper search" ;;
    zypper:list)      echo "zypper search --installed-only" ;;

    emerge:install)   echo "emerge" ;;
    emerge:remove)    echo "emerge --unmerge" ;;
    emerge:update)    echo "emerge --sync" ;;
    emerge:upgrade)   echo "emerge -uDN @world" ;;
    emerge:search)    echo "emerge --search" ;;
    emerge:list)      echo "qlist -I" ;;

    # clean: drop the downloaded-package cache (apt-clean style). -Scc and
    # the noconfirm/assume-yes flags keep it non-interactive. emerge has no
    # built-in cache clean (distfiles need gentoolkit's eclean) -> unsupported.
    pacman:clean)         echo "pacman -Scc --noconfirm" ;;
    apt-get:clean)        echo "apt-get clean" ;;
    dnf:clean)            echo "dnf clean packages" ;;
    apk:clean)            echo "apk cache clean" ;;
    xbps-install:clean)   echo "xbps-remove -Oy" ;;
    zypper:clean)         echo "zypper clean" ;;
    emerge:clean)         echo "" ;;

    *) ;;
    esac
}

# Read-only "is this package available in the layer's repos?" query command
# for a package manager. Run under a plain chroot (metadata lookups need no
# bind mounts, which also avoids layer-enable's persistent mounts). The PM's
# command must exit non-zero when the package is unknown. An empty mapping
# means "no reliable check" -> caller treats that layer as unconfirmable.
pm_available_cmd()
{
    case "$1" in
    pacman)        echo "pacman -Si" ;;          # non-zero if not in sync db
    apt-get)       echo "apt-cache show" ;;       # non-zero if unknown
    dnf)           echo "dnf -q info" ;;
    apk)           echo "apk add --simulate" ;;   # non-zero if unresolvable
    xbps-install)  echo "xbps-query -R" ;;        # remote repo lookup
    zypper)        echo "zypper -q se -x" ;;       # exact search; 104 if none
    emerge)        echo "" ;;                      # no reliable name-only check
    *) ;;
    esac
}

[ "$#" -ge 1 ] || usage
op="$1"
shift

case "$op" in
install|remove|update|upgrade|search|list|clean) ;;
*) usage ;;
esac

# Every pmm operation enters a layer (chroot/mount), so all need root; bail
# early with a clear message instead of cryptic chroot/mount errors.
if [ "$(id -u)" -ne 0 ]; then
    echo "pmm: '$op' needs root privileges. Re-run with: sudo pmm $op ..." >&2
    exit 1
fi

# Optional explicit target: layer:<name>
layer=""
case "${1:-}" in
layer:*)
    layer="${1#layer:}"
    shift
    ;;
esac

# List installed layer names (directories under LAYER_DIR).
installed_layers()
{
    for d in "$LAYER_DIR"/*/; do
        [ -d "$d" ] && basename "$d"
    done
}

# command -v equivalent for a layer: does it provide this command? Checked
# by looking at the layer's bin dirs directly - no chroot needed.
layer_has_cmd()
{
    for _d in usr/bin bin usr/sbin sbin usr/local/bin usr/local/sbin; do
        [ -e "$LAYER_DIR/$1/$_d/$2" ] && return 0
    done
    return 1
}

# First installed layer in exec_order priority (the base, e.g. enux, has no
# dir and is skipped); else the first layer dir present.
default_layer()
{
    _conf="${ENUX_CONF:-/enux/etc/enux.conf}"
    # Word-splitting is intended: layer names from exec_order, space-separated.
    # shellcheck disable=SC2013
    for _c in $(awk -F'=' '/^[ \t]*exec_order/ {gsub(/[ \t]/,"",$2); gsub(/,/," ",$2); print $2; exit}' "$_conf" 2>/dev/null); do
        [ -d "$LAYER_DIR/$_c" ] && { echo "$_c"; return 0; }
    done
    installed_layers | head -n1
}

# Layers in resolution priority: exec_order first, then any remaining
# installed layers (matches enux's cross ordering).
priority_layers()
{
    _conf="${ENUX_CONF:-/enux/etc/enux.conf}"
    _ordered=""
    # Word-splitting intended: exec_order layer names, space-separated.
    # shellcheck disable=SC2013
    for _c in $(awk -F'=' '/^[ \t]*exec_order/ {gsub(/[ \t]/,"",$2); gsub(/,/," ",$2); print $2; exit}' "$_conf" 2>/dev/null); do
        [ -d "$LAYER_DIR/$_c" ] && _ordered="$_ordered $_c"
    done
    for _d in "$LAYER_DIR"/*/; do
        [ -d "$_d" ] || continue
        _n=$(basename "$_d")
        case " $_ordered " in *" $_n "*) ;; *) _ordered="$_ordered $_n" ;; esac
    done
    # Word-splitting intended: emit the names space-separated for the caller.
    # shellcheck disable=SC2086
    echo $_ordered
}

# Is a package available in a layer's repos? 0 = yes, non-zero = no/unknown.
# sh -l gives the lookup a valid in-layer PATH (enux extends /etc/profile).
pkg_available()
{
    _l="$1"; _pm="$2"; _pkg="$3"
    _chk=$(pm_available_cmd "$_pm")
    [ -n "$_chk" ] || return 1
    chroot "$LAYER_DIR/$_l" /bin/sh -lc "$_chk \"\$1\"" sh "$_pkg" >/dev/null 2>&1
}

# Pick the first priority layer whose package manager has ALL the requested
# packages available (Bedrock's "first, is-package-available"). Returns 1 if
# none can be confirmed, so the caller falls back to the default layer rather
# than regressing.
find_install_layer()
{
    for _l in $(priority_layers); do
        _pm=$(detect_pm "$LAYER_DIR/$_l") || continue
        _all=1
        for _p in "$@"; do
            pkg_available "$_l" "$_pm" "$_p" || { _all=0; break; }
        done
        [ "$_all" = 1 ] && { echo "$_l"; return 0; }
    done
    return 1
}

# Run op in one layer with the given packages; returns the PM's exit status.
run_in_layer()
{
    _layer="$1"; shift
    [ -d "$LAYER_DIR/$_layer" ] || { echo "pmm: layer '$_layer' is not installed" >&2; return 1; }
    _pm=$(detect_pm "$LAYER_DIR/$_layer") || {
        echo "pmm: no supported package manager in layer '$_layer'" >&2
        return 1
    }
    _cmd=$(pm_command "$_pm" "$op")
    [ -n "$_cmd" ] || { echo "pmm: '$op' not supported for $_pm" >&2; return 1; }
    echo "pmm: [$_layer/$_pm] $_cmd $*"
    # shellcheck disable=SC2086  # $_cmd is an intentional multi-word command
    "$BIN_DIR/layer" enter "$_layer" $_cmd "$@"
}

rc=0
mutated=0

if [ -n "$layer" ]; then
    # Explicit target: operate only on that layer.
    if run_in_layer "$layer" "$@"; then :; else rc=$?; fi
    case "$op" in install|remove|upgrade) mutated=1 ;; esac
elif [ "$op" = remove ]; then
    # No explicit target: remove from EVERY layer that has the command, so
    # `pmm remove X` actually makes X gone rather than from just one layer.
    found=0
    for l in $(installed_layers); do
        present=""
        for pkg in "$@"; do
            layer_has_cmd "$l" "$pkg" && present="$present $pkg"
        done
        [ -n "$present" ] || continue
        found=1; mutated=1
        # shellcheck disable=SC2086  # $present is an intentional word list
        if run_in_layer "$l" $present; then :; else rc=$?; fi
    done
    [ "$found" = 1 ] || { echo "pmm: '$*' not found in any layer" >&2; exit 1; }
elif [ "$op" = install ]; then
    # No explicit target: install into the first layer (in exec_order
    # priority) that actually has the package(s) available, like Bedrock's
    # pmm. Fall back to the configured default if availability can't be
    # confirmed (e.g. indexes not synced yet, or a check-less PM).
    target=$(find_install_layer "$@") || {
        target=$(default_layer)
        [ -n "$target" ] && echo "pmm: could not confirm availability; defaulting to '$target' (try 'pmm update' first, or use layer:<name>)" >&2
    }
    [ -n "$target" ] || { echo "pmm: no installed layer to target (use layer:<name>)" >&2; exit 1; }
    if run_in_layer "$target" "$@"; then :; else rc=$?; fi
    mutated=1
else
    # No explicit target for update/upgrade/search/list/clean: apply to EVERY
    # installed layer (Bedrock's "every" applicability). Refreshing/upgrading,
    # searching, or clearing caches on just one layer ignored the rest.
    any=0
    for l in $(installed_layers); do
        detect_pm "$LAYER_DIR/$l" >/dev/null 2>&1 || continue
        any=1
        if run_in_layer "$l" "$@"; then :; else rc=$?; fi
    done
    [ "$any" = 1 ] || { echo "pmm: no installed layer with a package manager" >&2; exit 1; }
    case "$op" in upgrade) mutated=1 ;; esac
fi

# install/remove/upgrade change which commands layers provide -> refresh
# the cross wrappers once afterward.
[ "$mutated" = 1 ] && { "$BIN_DIR/enux" cross >/dev/null 2>&1 || true; }
exit "$rc"
