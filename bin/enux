#!/bin/sh
# enux - layer lifecycle manager (the brl clone)
#
# Owns /enux/etc/enux.conf's [layers] section (exec_order, active) and the
# install/remove of layer rootfses under /enux/layer/. Mount/chroot
# mechanics are layer's job, not this command's - enux only ever calls
# `layer enable/disable`, never touches mounts directly.
#
# Usage:
#   enux install <name> [url-or-tarball-path]
#   enux remove <name>
#   enux list
#   enux show <name>
#   enux set-exec-order <name> [name...]
#   enux exec <command> [args...]

set -eu

BIN_DIR="${BIN_DIR:-/enux/bin}"
LAYER_DIR="${LAYER_DIR:-/enux/layer}"
LIBEXEC_DIR="${LIBEXEC_DIR:-/enux/libexec}"
CROSS_DIR="${CROSS_DIR:-/enux/cross}"
ENUX_CONF="${ENUX_CONF:-/enux/etc/enux.conf}"

# Strip the cross dir from our own PATH. cross wrappers run a command
# inside a layer's chroot; if enux's helpers (curl/wget/tar) resolved to a
# wrapper, they would execute in that chroot and fail on base paths - e.g.
# downloading to a base /tmp dir that does not exist inside the layer.
# Base tooling must use the base system's real binaries.
case ":$PATH:" in
*":$CROSS_DIR/bin:"*)
    _np=""; _oifs=$IFS; IFS=:
    for _p in $PATH; do
        [ "$_p" = "$CROSS_DIR/bin" ] && continue
        _np="${_np:+$_np:}$_p"
    done
    IFS=$_oifs
    PATH=$_np; export PATH
    ;;
esac

usage()
{
    cat >&2 <<'EOF'
usage: enux install <name> [url-or-tarball-path]
       enux remove <name>
       enux list
       enux show <name>
       enux set-exec-order <name> [name...]
       enux exec <command> [args...]
       enux which <command> [command...]
       enux cross
       enux configure <name>
EOF
    exit 2
}

# --- HTTP helpers ----------------------------------------------------
#
# Prefer curl, fall back to wget. Minimal targets (LFS, some containers)
# often ship only one of the two; The ENux Layer must work on either.

# Set ENUX_FETCH_INSECURE=1 to skip TLS certificate verification. Needed
# only on systems without a CA bundle (a bare LFS lacks ca-certificates);
# the real fix is to install ca-certificates. Default is to verify.
if [ "${ENUX_FETCH_INSECURE:-0}" = 1 ]; then
    CURL_TLS="-k"
    WGET_TLS="--no-check-certificate"
else
    CURL_TLS=""
    WGET_TLS=""
fi

# Fetch a URL to stdout, failing on HTTP errors.
http_get()
{
    if command -v curl >/dev/null 2>&1; then
        curl $CURL_TLS -sfL "$1"
    elif command -v wget >/dev/null 2>&1; then
        wget $WGET_TLS -qO- "$1"
    else
        echo "enux: need curl or wget to fetch $1" >&2
        return 1
    fi
}

# Download a URL ($1) to a file ($2), failing on HTTP errors.
http_download()
{
    if command -v curl >/dev/null 2>&1; then
        curl $CURL_TLS -fL -o "$2" "$1"
    elif command -v wget >/dev/null 2>&1; then
        wget $WGET_TLS -O "$2" "$1"
    else
        echo "enux: need curl or wget to download $1" >&2
        return 1
    fi
}

# --- enux.conf [layers] section helpers ------------------------------
#
# Format (shared with init.c's bedrock_conf.c parser):
#   [layers]
#   exec_order = name1,name2
#   active = name1

conf_get()
{
    section="$1"; key="$2"
    [ -f "$ENUX_CONF" ] || return 0
    awk -v section="$section" -v key="$key" '
        /^\[/ { cur = substr($0, 2, length($0)-2); next }
        cur == section {
            split($0, kv, "=")
            k = kv[1]; gsub(/^[ \t]+|[ \t]+$/, "", k)
            if (k == key) {
                v = substr($0, index($0, "=")+1)
                gsub(/^[ \t]+|[ \t]+$/, "", v)
                print v
                exit
            }
        }
    ' "$ENUX_CONF"
}

# Set key=value inside [section], creating the section/file if missing.
conf_set()
{
    section="$1"; key="$2"; value="$3"
    touch "$ENUX_CONF"
    tmp="$ENUX_CONF.tmp.$$"
    awk -v section="$section" -v key="$key" -v value="$value" '
        BEGIN { in_section = 0; done = 0 }
        /^\[/ {
            cur = substr($0, 2, length($0)-2)
            if (in_section && !done) {
                print key " = " value
                done = 1
            }
            in_section = (cur == section)
            print
            next
        }
        {
            if (in_section) {
                split($0, kv, "=")
                k = kv[1]; gsub(/^[ \t]+|[ \t]+$/, "", k)
                if (k == key) {
                    print key " = " value
                    done = 1
                    next
                }
            }
            print
        }
        END {
            if (!done && in_section) {
                print key " = " value
                done = 1
            }
            if (!done) {
                print "[" section "]"
                print key " = " value
            }
        }
    ' "$ENUX_CONF" > "$tmp"
    mv "$tmp" "$ENUX_CONF"
}

exec_order_list()
{
    order=$(conf_get layers exec_order)
    [ -n "$order" ] || return 0
    echo "$order" | tr ',' '\n' | sed 's/^ *//; s/ *$//'
}

exec_order_add()
{
    name="$1"
    existing=$(exec_order_list | tr '\n' ',' | sed 's/,$//')
    case ",$existing," in
    *",$name,"*) return 0 ;;
    esac
    if [ -n "$existing" ]; then
        conf_set layers exec_order "$existing,$name"
    else
        conf_set layers exec_order "$name"
    fi
}

exec_order_remove()
{
    name="$1"
    new=$(exec_order_list | grep -v "^$name\$" | tr '\n' ',' | sed 's/,$//')
    conf_set layers exec_order "$new"
}

# --- rootfs fetch: known layers have a builtin default source --------

# Newest release dir for a linuxcontainers distro (e.g. fedora -> 44).
# Releases are listed as subdirectories; numeric versions sort correctly
# with `sort -V`. Named releases (debian's "bookworm" etc.) would need a
# pinned release arg instead - that path isn't handled here yet.
lxc_latest_release()
{
    distro="$1"
    http_get "https://images.linuxcontainers.org/images/$distro/" \
        | grep -oE 'href="[^"/]+/"' \
        | sed 's/href="//; s|/"||' \
        | grep -vE '^\.\.$' \
        | sort -V \
        | tail -n1
}

# Resolve a downloadable rootfs.tar.xz under a linuxcontainers image dir.
# Args: <distro> <release> [variant]  (variant defaults to "default";
# gentoo has no "default" and uses openrc/systemd instead).
# Honors the rule: prefer an explicit "latest" alias if the mirror has
# one, otherwise pick the newest timestamped upload. Timestamp dirs look
# like 20260622_02%3A12/ (the %3A is a URL-encoded colon).
lxc_rootfs_url()
{
    distro="$1"
    release="$2"
    variant="${3:-default}"
    [ -n "$release" ] || return 1
    base="https://images.linuxcontainers.org/images/$distro/$release/amd64/$variant"
    listing=$(http_get "$base/") || return 1

    if echo "$listing" | grep -q 'href="latest/"'; then
        sub="latest/"
    else
        sub=$(echo "$listing" \
            | grep -oE 'href="[0-9]{8}_[0-9]{2}%3A[0-9]{2}/"' \
            | sed 's/href="//; s/"//' \
            | sort \
            | tail -n1)
    fi
    [ -n "$sub" ] || return 1
    echo "$base/${sub}rootfs.tar.xz"
}

default_source()
{
    case "$1" in
    arch)
        # Arch ships a permanent version-less "latest" alias.
        echo "https://geo.mirror.pkgbuild.com/iso/latest/archlinux-bootstrap-x86_64.tar.zst"
        ;;
    alpine)
        # Alpine's minirootfs filename is versioned and has no permanent
        # "latest" alias - resolve the current one from the listing.
        base="https://dl-cdn.alpinelinux.org/alpine/latest-stable/releases/x86_64"
        file=$(http_get "$base/" | grep -oE 'alpine-minirootfs-[0-9.]+-x86_64\.tar\.gz' | head -n1)
        [ -n "$file" ] && echo "$base/$file"
        ;;
    # linuxcontainers-served distros. Numeric-release ones (fedora, rocky,
    # centos) auto-detect the newest; the rest use codenames or "current"
    # that sort -V can't rank, so their release is pinned to a sensible
    # default. The third arg is the image variant (gentoo has no
    # "default"). Friendly layer names map to linuxcontainers identifiers
    # (void -> voidlinux).
    fedora|rockylinux|centos)
        lxc_rootfs_url "$1" "$(lxc_latest_release "$1")" default
        ;;
    debian)
        lxc_rootfs_url debian trixie default
        ;;
    ubuntu)
        lxc_rootfs_url ubuntu noble default
        ;;
    opensuse)
        lxc_rootfs_url opensuse 16.0 default
        ;;
    void)
        lxc_rootfs_url voidlinux current default
        ;;
    gentoo)
        lxc_rootfs_url gentoo current openrc
        ;;
    *)
        ;;
    esac
}

# A directory looks like a root filesystem if it has /etc and either a
# /usr or a /bin. Used to locate the real rootfs inside an extracted
# tarball, whatever wrapping the distro uses.
is_rootfs()
{
    [ -d "$1/etc" ] && { [ -d "$1/usr" ] || [ -d "$1/bin" ]; }
}

fetch_and_extract()
{
    src="$1"
    dest="$2"
    work="$(mktemp -d)"
    trap 'rm -rf "$work"' EXIT

    # Extract into a clean subdir so the downloaded archive never ends up
    # mixed in with (and mistaken for) the extracted contents.
    xdir="$work/extract"
    mkdir -p "$xdir"

    case "$src" in
    *.tar.zst) ext=tar.zst ;;
    *.tar.xz)  ext=tar.xz ;;
    *.tar.gz|*.tgz) ext=tar.gz ;;
    *) ext=tar ;;
    esac

    case "$src" in
    http://*|https://*)
        archive="$work/download.$ext"     # sits outside $xdir
        http_download "$src" "$archive"
        ;;
    *)
        [ -f "$src" ] || { echo "enux: no such file: $src" >&2; exit 1; }
        archive="$src"
        ;;
    esac

    case "$archive" in
    *.tar.zst) tar --use-compress-program=unzstd -xf "$archive" -C "$xdir" ;;
    *.tar.xz)  tar -xJf "$archive" -C "$xdir" ;;
    *.tar.gz|*.tgz) tar -xzf "$archive" -C "$xdir" ;;
    *) echo "enux: unrecognized archive format: $archive" >&2; exit 1 ;;
    esac

    # Find the actual rootfs. Some tarballs are a flat rootfs (alpine
    # minirootfs, linuxcontainers rootfs.tar.xz); Arch's bootstrap wraps
    # it in root.x86_64/ next to pkglist/version metadata files.
    rootfs=""
    if is_rootfs "$xdir"; then
        rootfs="$xdir"
    else
        for d in "$xdir"/*/; do
            [ -d "$d" ] || continue
            if is_rootfs "$d"; then
                rootfs="${d%/}"
                break
            fi
        done
    fi
    [ -n "$rootfs" ] || {
        echo "enux: no root filesystem found in $src" >&2
        exit 1
    }

    mkdir -p "$(dirname "$dest")"
    mv "$rootfs" "$dest.movetmp"
    rmdir "$dest" 2>/dev/null || true
    mv "$dest.movetmp" "$dest"
}

# --- per-distro post-install configuration ---------------------------

# Set up a freshly installed layer's package repositories (and signing
# keys) so its package manager works immediately. Bootstrap rootfses ship
# without usable repo config: Arch's mirrorlist is all-commented and its
# keyring is empty; Alpine's minirootfs has no repositories file. Runs in
# a subshell so its variables don't leak into the caller.
configure_layer()
(
    name="$1"
    dest="$LAYER_DIR/$name"

    case "$name" in
    arch)
        # $repo/$arch must stay literal - pacman expands them, not us.
        # shellcheck disable=SC2016
        echo 'Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch' \
            > "$dest/etc/pacman.d/mirrorlist"
        # pacman-key must run inside the layer (it writes the layer's
        # keyring and uses its gpg). Slow but needed for signed installs.
        echo "enux: initializing pacman keyring for arch (takes a moment)..."
        if "$BIN_DIR/layer" enter arch /bin/sh -c \
              'pacman-key --init && pacman-key --populate archlinux' \
              >/dev/null 2>&1; then
            "$BIN_DIR/layer" disable arch >/dev/null 2>&1 || true
        else
            "$BIN_DIR/layer" disable arch >/dev/null 2>&1 || true
            echo "enux: warning: pacman keyring init failed; run" \
                 "'layer enter arch pacman-key --init && ... --populate archlinux'" >&2
        fi
        ;;
    alpine)
        # Derive the release (e.g. 3.24) from the rootfs and point apk at
        # the matching main + community repositories.
        ver=$(cut -d. -f1,2 "$dest/etc/alpine-release" 2>/dev/null || true)
        if [ -n "$ver" ]; then
            {
                echo "https://dl-cdn.alpinelinux.org/alpine/v$ver/main"
                echo "https://dl-cdn.alpinelinux.org/alpine/v$ver/community"
            } > "$dest/etc/apk/repositories"
        fi
        ;;
    debian|ubuntu)
        # apt won't install anything until the package lists are fetched
        # once, and apt-get install has no combined sync flag. Prime them.
        echo "enux: updating apt package lists for $name..."
        "$BIN_DIR/layer" enter "$name" /bin/sh -c 'apt-get update' \
            >/dev/null 2>&1 || \
            echo "enux: warning: apt-get update failed; run it before installing" >&2
        "$BIN_DIR/layer" disable "$name" >/dev/null 2>&1 || true
        ;;
    opensuse)
        # Refresh zypper repos so the first install doesn't stall on it.
        "$BIN_DIR/layer" enter "$name" /bin/sh -c \
            'zypper --non-interactive --gpg-auto-import-keys refresh' \
            >/dev/null 2>&1 || true
        "$BIN_DIR/layer" disable "$name" >/dev/null 2>&1 || true
        ;;
    gentoo)
        # emerge needs a portage tree, which the stage image does not
        # include. Syncing it is large/slow, so it is left to the user.
        echo "enux: note - gentoo needs a portage tree before emerge works:" \
             "run 'layer enter gentoo emerge-webrsync' (large download)" >&2
        ;;
    *)
        # fedora/void and other linuxcontainers images ship working repo config.
        ;;
    esac
)

# --- cross commands --------------------------------------------------

# (Re)build /enux/cross/bin: one symlink per command found in the
# non-base layers, pointing at cross-dispatch, plus an index mapping each
# command to the layer that provides it. exec_order decides priority -
# the first layer to claim a command name wins.
# Body runs in a subshell ( ) so its working variables (name, layer, ...)
# never leak into callers like cmd_install, which has its own $name.
cross_update()
(
    bindir="$CROSS_DIR/bin"
    index="$CROSS_DIR/index"
    dispatch="$LIBEXEC_DIR/cross-dispatch"

    if [ ! -x "$dispatch" ]; then
        echo "enux: $dispatch missing; cannot build cross commands" >&2
        exit 1
    fi

    # Build into temporaries and swap at the end, so the live $bindir/$index
    # are never seen empty or half-built. A naive rm+recreate leaves a
    # multi-second window where 'command not found' hits any concurrent lookup
    # (e.g. an auto-refresh after a package install racing the next command).
    newbin="$CROSS_DIR/.bin.new.$$"
    newindex="$CROSS_DIR/.index.new.$$"
    rm -rf "$newbin"
    mkdir -p "$newbin" "$CROSS_DIR"
    : > "$newindex"

    # Base root that owns this cross dir: /enux/cross -> "" (i.e. /), or
    # /mnt/lfs2/enux/cross -> /mnt/lfs2. Commands the base already provides
    # are skipped, so coreutils (basename, ls, sh...) are never wrapped -
    # only distro-unique tools (pacman, apk, dnf...) get crossed. This also
    # removes any chance of cross-dispatch recursing through a wrapped
    # coreutil.
    base_root="${CROSS_DIR%/enux/cross}"
    [ "$base_root" = "$CROSS_DIR" ] && base_root=""

    base_has()
    {
        for _bd in usr/bin bin usr/sbin sbin; do
            [ -e "$base_root/$_bd/$1" ] && return 0
        done
        return 1
    }

    # Cross every installed layer. exec_order sets priority for command
    # name conflicts; any installed layer not in exec_order is appended.
    # The base layer (e.g. enux) has no dir under /enux/layer, so it is
    # naturally excluded - its commands are already native on PATH.
    ordered=""
    for l in $(exec_order_list); do
        [ -d "$LAYER_DIR/$l" ] || continue
        ordered="$ordered $l"
    done
    for d in "$LAYER_DIR"/*/; do
        [ -d "$d" ] || continue
        name=$(basename "$d")
        case " $ordered " in *" $name "*) ;; *) ordered="$ordered $name" ;; esac
    done

    for layer in $ordered; do
        root="$LAYER_DIR/$layer"
        [ -d "$root" ] || continue
        for d in usr/bin bin usr/sbin sbin; do
            [ -d "$root/$d" ] || continue
            for f in "$root/$d"/*; do
                [ -f "$f" ] && [ -x "$f" ] || continue
                cmd=$(basename "$f")
                # Base commands reach other layers ONLY via the enux base-mirror
                # layer; for every other layer skip what the base already
                # provides (keeps cross to that distro's own commands). enux is
                # first in exec_order so it claims base commands; distro-unique
                # ones (pacman, apt...) still resolve to their own layer.
                if [ "$layer" != enux ] && base_has "$cmd"; then
                    continue
                fi
                grep -q "^$cmd " "$newindex" 2>/dev/null && continue
                # Record the command's absolute path *inside* the layer so
                # the dispatcher can exec it directly under chroot, instead
                # of relying on PATH resolution (Alpine's apk is in /sbin,
                # which the caller's PATH may not include).
                echo "$cmd $layer /$d/$cmd" >> "$newindex"
                ln -sf "$dispatch" "$newbin/$cmd"
            done
        done
    done

    # Swap into place. The index is one atomic rename. The bin dir is swapped
    # with two quick renames (a microsecond window) instead of the seconds-long
    # rebuild, so concurrent lookups effectively never miss.
    mv -f "$newindex" "$index"
    rm -rf "$bindir.old"
    [ -e "$bindir" ] && mv "$bindir" "$bindir.old"
    mv "$newbin" "$bindir"
    rm -rf "$bindir.old"
    echo "enux: cross commands updated ($(wc -l < "$index" | tr -d ' ') commands)"
)

# --- subcommands -------------------------------------------------------

# Copy the ENux Layer command set, cross dir, and libexec into a layer, so
# the tooling and cross commands are reachable from inside it. libexec is
# required: the cross symlinks point at /enux/libexec/cross-dispatch and the
# bin commands call /enux/libexec/layer-*. cp -a preserves symlinks (the
# cross dir is hundreds of links) and does NOT dereference them.
copy_tooling_into_layer()
{
    dst="$1"
    mkdir -p "$dst/enux"
    rm -rf "$dst/enux/bin" "$dst/enux/cross" "$dst/enux/libexec"
    cp -a "$BIN_DIR" "$dst/enux/bin"
    cp -a "$LIBEXEC_DIR" "$dst/enux/libexec"
    [ -d "$CROSS_DIR" ] && cp -a "$CROSS_DIR" "$dst/enux/cross"

    # Put the ENux tooling + cross commands on PATH. Appended to /etc/profile
    # (not bash.bashrc): `layer enter` starts /bin/sh -l, a login shell, which
    # sources /etc/profile - and it works for sh, not just bash. Single-quoted
    # so $PATH stays literal in the file (expanded at runtime). Idempotent;
    # appended last so it extends whatever PATH the distro's profile sets.
    rc="$dst/etc/profile"
    if ! grep -qF '/enux/cross/bin' "$rc" 2>/dev/null; then
        mkdir -p "$dst/etc"
        # $PATH must stay literal in the file (expanded at runtime).
        # shellcheck disable=SC2016
        printf '\n# ENux Layer: tooling and cross commands\nexport PATH="$PATH:/enux/bin:/enux/cross/bin"\n' >> "$rc"
    fi
}

cmd_install()
{
    [ "$#" -ge 1 ] || usage
    name="$1"
    src="${2:-$(default_source "$name")}"
    dest="$LAYER_DIR/$name"

    [ -d "$dest" ] && { echo "enux: '$name' is already installed at $dest" >&2; exit 1; }
    [ -n "$src" ] || {
        echo "enux: no builtin source for '$name' - pass a URL or tarball path" >&2
        exit 1
    }

    echo "enux: fetching $src"
    fetch_and_extract "$src" "$dest"
    exec_order_add "$name"
    configure_layer "$name"     # set up package repos / keys
    "$LIBEXEC_DIR/layer-provision" "$name" || true   # host user + locale
    cross_update || true        # keep cross commands in sync; non-fatal
    copy_tooling_into_layer "$dest"   # make /enux/bin + /enux/cross available inside it
    echo "enux: '$name' installed at $dest"
}

cmd_remove()
{
    [ "$#" -eq 1 ] || usage
    name="$1"
    dest="$LAYER_DIR/$name"
    [ -d "$dest" ] || { echo "enux: '$name' is not installed" >&2; exit 1; }

    # Never rm -rf a mounted layer - disable it first (see commit history:
    # this is exactly how a chroot's live /proc and /dev almost got baked
    # into a squashfs image during testing).
    "$BIN_DIR/layer" disable "$name"
    rm -rf "$dest"
    exec_order_remove "$name"
    cross_update || true        # drop the removed layer's cross commands
    echo "enux: '$name' removed"
}

cmd_list()
{
    active=$(conf_get layers active)
    [ -d "$LAYER_DIR" ] || { echo "no layers installed"; return 0; }
    for d in "$LAYER_DIR"/*/; do
        [ -d "$d" ] || continue
        name=$(basename "$d")
        marker=" "
        [ "$name" = "$active" ] && marker="*"
        printf '%s %s\n' "$marker" "$name"
    done
}

cmd_show()
{
    [ "$#" -eq 1 ] || usage
    name="$1"
    dest="$LAYER_DIR/$name"
    [ -d "$dest" ] || { echo "enux: '$name' is not installed" >&2; exit 1; }
    echo "name:       $name"
    echo "path:       $dest"
    echo "size:       $(du -sh "$dest" 2>/dev/null | cut -f1)"
    echo "exec_order: $(exec_order_list | tr '\n' ',' | sed 's/,$//')"
    "$BIN_DIR/layer" list | awk -v n="$name" '$1==n{print "state:      " $2}'
}

cmd_set_exec_order()
{
    [ "$#" -ge 1 ] || usage
    for name in "$@"; do
        [ -d "$LAYER_DIR/$name" ] || {
            echo "enux: '$name' is not installed" >&2
            exit 1
        }
    done
    order=$(printf '%s,' "$@")
    order="${order%,}"
    conf_set layers exec_order "$order"
}

cmd_exec()
{
    [ "$#" -ge 1 ] || usage
    first=$(exec_order_list | head -n1)
    [ -n "$first" ] || { echo "enux: exec_order is empty" >&2; exit 1; }
    exec "$BIN_DIR/layer" enter "$first" "$@"
}

# Report what provides a command: the base directly, or (via cross) a layer.
# Read-only - mirrors cross's base-vs-layer resolution so users can see where
# a name will actually run from.
cmd_which()
{
    [ "$#" -ge 1 ] || usage
    _base="${CROSS_DIR%/enux/cross}"
    [ "$_base" = "$CROSS_DIR" ] && _base=""
    _rc=0
    for _c in "$@"; do
        _hit=""
        for _bd in usr/local/sbin usr/local/bin usr/sbin usr/bin sbin bin; do
            [ -x "$_base/$_bd/$_c" ] && { _hit="base (/$_bd/$_c)"; break; }
        done
        if [ -z "$_hit" ] && [ -f "$CROSS_DIR/index" ]; then
            _hit=$(awk -v c="$_c" '$1 == c { printf "layer %s (%s, via cross)", $2, $3; exit }' "$CROSS_DIR/index")
        fi
        [ -n "$_hit" ] || { _hit="not found"; _rc=1; }
        printf '%-20s %s\n' "$_c" "$_hit"
    done
    return "$_rc"
}

# Operations that fetch/mount or write the root-owned /enux tree need root;
# bail early with a clear message instead of cryptic mount/permission errors.
need_root()
{
    [ "$(id -u)" -eq 0 ] && return 0
    echo "enux: '$1' needs root privileges. Re-run with: sudo enux $1 ..." >&2
    exit 1
}

[ "$#" -ge 1 ] || usage
cmd="$1"
shift

case "$cmd" in
install)         need_root install;        cmd_install "$@" ;;
remove)          need_root remove;         cmd_remove "$@" ;;
list)            cmd_list "$@" ;;
show)             cmd_show "$@" ;;
set-exec-order)  need_root set-exec-order; cmd_set_exec_order "$@" ;;
exec)            need_root exec;           cmd_exec "$@" ;;
which)           cmd_which "$@" ;;
cross)           need_root cross;          cross_update ;;
configure)       need_root configure; [ "$#" -eq 1 ] || usage; [ -d "$LAYER_DIR/$1" ] || { echo "enux: '$1' is not installed" >&2; exit 1; }; configure_layer "$1" ;;
*)               usage ;;
esac
