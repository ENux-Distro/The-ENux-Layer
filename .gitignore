# Build artifact: the init binary is built from the separate init.c repo
# (make init / make INIT_SRC=...). Not committed.
/sbin/init

# Installed layer rootfilesystems are runtime/per-build data.
/layer/*
!/layer/.keep

# A local checkout of the separate init.c repo (ENux-Distro/init.c) sometimes
# lives here for `make init`; it is its own repo and is never vendored.
/init.c/
libexec/layer-chroot
